{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gamerat",
  "version": "../package.json",
  "identifier": "org.appulsauce.gamerat",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "gamerat",
        "width": 1024,
        "height": 720,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "Per-application mouse profile dispatcher.",
    "longDescription": "gamerat layers gaming-oriented per-application hardware profiles on top of ratbagd / libratbag."
  }
}
