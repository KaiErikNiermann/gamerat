{
  "name": "gamerat-gui",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "description": "Tauri + Svelte desktop frontend for gamerat.",
  "license": "GPL-2.0-or-later",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "messages": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --strategy localStorage preferredLanguage baseLocale --emit-ts-declarations",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "precheck": "pnpm messages",
    "lint": "eslint .",
    "prelint": "pnpm messages",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "pretest": "pnpm messages",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:a11y": "playwright test",
    "tauri": "WEBKIT_DISABLE_DMABUF_RENDERER=1 WEBKIT_DISABLE_COMPOSITING_MODE=1 GDK_BACKEND=x11 tauri"
  },
  "dependencies": {
    "@lucide/svelte": "^1.21.0",
    "@tauri-apps/api": "^2",
    "svelte-awesome-color-picker": "^4.1.3",
    "ts-pattern": "^5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10",
    "@inlang/paraglide-js": "^2.20.1",
    "@playwright/test": "^1.61.0",
    "@sveltejs/vite-plugin-svelte": "^6",
    "@tailwindcss/vite": "^4",
    "@tauri-apps/cli": "^2",
    "@types/node": "^26",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10",
    "eslint-plugin-security": "^4",
    "eslint-plugin-sonarjs": "^4",
    "eslint-plugin-svelte": "^3",
    "eslint-plugin-unicorn": "^66",
    "globals": "^17",
    "jsdom": "^29.1.1",
    "svelte": "^5",
    "svelte-check": "^4",
    "svelte-eslint-parser": "^1",
    "tailwindcss": "^4",
    "tslib": "^2",
    "typescript": "^6.0",
    "typescript-eslint": "^8",
    "vite": "^6",
    "vitest": "^4.1.9"
  }
}
