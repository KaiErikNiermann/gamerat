<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE node PUBLIC
  "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
  "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">

<!--
  org.appulsauce.GameRat1 — top-level manager interface for the gamerat
  daemon.

  This XML is the authoritative wire-level spec. The Rust proxy trait in
  `gamerat-proto::proxy` mirrors it; the two must stay in sync. A CI
  drift check will land once we have a stable surface.

  Stability: experimental. Breaking changes bump the suffix to GameRat2.
-->
<node>
  <interface name="org.appulsauce.GameRat1">

    <!-- ===== Focus injection (synthetic + external bridges) ===== -->

    <!--
      Inject a synthetic focus event as if a window just gained the
      input focus. The daemon treats this identically to a real focus
      event from a backend, runs it through the rule matcher, and
      emits FocusChanged (then, if a rule matches, ProfileSwitched).

      Source label on FocusChanged is `synthetic`. Used by the CLI's
      `gameratctl focus simulate` and by automated tests.
    -->
    <method name="SimulateFocus">
      <arg name="app_id" type="s" direction="in"/>
      <arg name="title" type="s" direction="in"/>
    </method>

    <!--
      Bridge entrypoint for KDE Plasma's KWin Script: forwards a
      window activation observed inside the compositor (KWin does not
      expose wlr-foreign-toplevel-management or plasma-window-management
      to unprivileged Wayland clients). The accompanying script lives
      in `data/kwin-script/gamerat-focus/`.

      Source label on FocusChanged is `kwin`. Functionally equivalent
      to SimulateFocus modulo the source tag.
    -->
    <method name="IngestKwinFocus">
      <arg name="app_id" type="s" direction="in"/>
      <arg name="title" type="s" direction="in"/>
    </method>

    <!-- ===== Rule management ===== -->

    <!--
      Upsert a rule. If a rule with the same glob already exists it is
      replaced. Rules persist to $XDG_CONFIG_HOME/gamerat/rules.toml.
    -->
    <!--
      `profile_id` references a `GameratProfile` stored by the daemon
      (see ListProfiles / SetProfile). Missing references are accepted
      but the rule stays inert until the profile is created.
    -->
    <method name="SetRule">
      <arg name="app_id_glob" type="s" direction="in"/>
      <arg name="profile_id" type="s" direction="in"/>
    </method>

    <method name="DeleteRule">
      <arg name="app_id_glob" type="s" direction="in"/>
    </method>

    <!--
      Returns: array of (app_id_glob, profile_id, created_unix).
      Encodes `gamerat_proto::types::Rule`.
    -->
    <method name="ListRules">
      <arg name="rules" type="a(sst)" direction="out"/>
    </method>

    <!-- ===== Device introspection ===== -->

    <!--
      Returns: array of (object_path, name, model, active_profile,
      profile_count). The object_path is ratbagd's, not the daemon's
      — clients pass it back unchanged. `model` is ratbagd's encoded
      bustype:vid:pid:version string; `name` is the human-readable
      device name.
      Encodes `gamerat_proto::types::DeviceInfo`.
    -->
    <method name="ListDevices">
      <arg name="devices" type="a(ossuuu)" direction="out"/>
    </method>

    <!-- ===== Software-abstracted profiles ===== -->

    <!--
      User-defined profiles live in user space and describe a set of
      device settings (currently: DPI stages only — buttons, LEDs,
      report rate land in later phases). The daemon never modifies
      these; they're the canonical "what does the user want this
      profile to mean" record.

      Wire shape for the struct (D-Bus `(sssssauuta(u(uua(uu))))`):
        id              stable id, e.g. "fps-low-dpi"
        name            human-readable, e.g. "FPS — low DPI"
        description     free text
        category        wire-stable: "agnostic" | "specific"
                        (see `gamerat_proto::game_category`)
        inherits_from   id of an agnostic profile this game-specific
                        profile is equivalent to, or "" for none.
                        Forward-compat slot for the future
                        equivalence-dedup feature.
        dpi             array of DPI stages (typically 1-5 cpi values)
        active_dpi_stage which dpi[] index is active by default
        created_unix    creation time
    -->
    <method name="ListProfiles">
      <arg name="profiles" type="a(sssssauuta(u(uua(uu))))" direction="out"/>
    </method>

    <method name="GetProfile">
      <arg name="id" type="s" direction="in"/>
      <arg name="profile" type="(sssssauuta(u(uua(uu))))" direction="out"/>
    </method>

    <!--
      Upsert: replaces any existing profile with the same `id`.
      The daemon persists each profile to
      `$XDG_CONFIG_HOME/gamerat/profiles.toml` (single combined file
      mirroring the rules store).
    -->
    <method name="SetProfile">
      <arg name="profile" type="(sssssauuta(u(uua(uu))))" direction="in"/>
    </method>

    <method name="DeleteProfile">
      <arg name="id" type="s" direction="in"/>
    </method>

    <!--
      Force the named profile onto the device immediately, bypassing
      focus rules and the autoswitch flag. Drives the same allocator
      decision / write-or-set-active / emit-ProfileSwitched path as
      a rule-matched switch. Used by manual-mode Apply in the GUI
      and by `gameratctl profile apply`.
    -->
    <method name="ApplyProfile">
      <arg name="profile_id" type="s" direction="in"/>
    </method>

    <!--
      Per-slot view for a device: which gamerat profile (if any)
      occupies each hardware slot, which slot is currently active,
      which is the reserved Desktop. Returns an array of SlotInfo
      `(index, profile_id, profile_name, is_active, is_desktop)`.
    -->
    <method name="GetSlotMap">
      <arg name="device_path" type="o" direction="in"/>
      <arg name="slots" type="a(ussbb)" direction="out"/>
    </method>

    <!--
      Active DPI stage index of the device's currently-active hardware
      profile. Lets the GUI keep its stage indicator in sync after a
      DPI-up / DPI-down / DPI-cycle press on the mouse itself.
    -->
    <method name="GetActiveDpiStage">
      <arg name="device_path" type="o" direction="in"/>
      <arg name="stage" type="u" direction="out"/>
    </method>

    <!--
      Force the device back to its reserved Desktop slot. Idempotent
      if Desktop is already active. Used by the GUI's manual-mode
      "Apply Base" affordance.
    -->
    <method name="ApplyBase"/>

    <!--
      Read the DPI stages and active stage index from the device's
      currently-active hardware profile. Drives the GUI's Base-mode
      DPI editor — no gamerat profile record to read from in that
      mode.
    -->
    <method name="GetActiveProfileDpi">
      <arg name="device_path" type="o" direction="in"/>
      <arg name="dpi" type="au" direction="out"/>
      <arg name="active_stage" type="u" direction="out"/>
    </method>

    <!--
      Per-resolution-slot answer to "can this slot be hardware-disabled?".
      Returns one bool per DPI slot on the device's currently-active
      profile; entry `i` is `true` iff slot `i` declares
      `RATBAG_RESOLUTION_CAP_DISABLE` (libratbag value 2). The GUI uses
      this to decide whether the "shorten DPI cycle" affordance is
      honest — without the cap, the firmware keeps every slot in the
      cycle regardless of the gamerat profile's stage count.
    -->
    <method name="GetDpiStageDisableCaps">
      <arg name="device_path" type="o" direction="in"/>
      <arg name="caps" type="ab" direction="out"/>
    </method>

    <!--
      Write DPI + button bindings to the device's currently-active
      hardware profile in one batched commit. Used by the GUI's
      Base-mode editor (DPI stage edits, Reset to defaults). `buttons`
      may be empty to skip the binding write — useful when only DPI
      is changing.
    -->
    <method name="ApplyToActiveProfile">
      <arg name="device_path" type="o" direction="in"/>
      <arg name="dpi" type="au" direction="in"/>
      <arg name="active_stage" type="u" direction="in"/>
      <arg name="buttons" type="a(u(uua(uu)))" direction="in"/>
      <arg name="leds" type="a(uu(uuu)u)" direction="in"/>
    </method>

    <!-- ===== Game library introspection ===== -->

    <!--
      Returns: array of (id, name, launcher, install_dir, executable,
      app_id_hint). Empty strings encode "absent" for the optional
      fields (install_dir / executable / app_id_hint).

      `launcher` is a wire-stable lowercase string from
      `gamerat_proto::game_launcher::*` ("steam", "lutris", "heroic",
      "other").

      The daemon scans installed Steam / Lutris / Heroic libraries
      once at startup and caches the result. Encodes
      `gamerat_proto::types::GameEntry`.
    -->
    <method name="ListGames">
      <arg name="games" type="a(ssssss)" direction="out"/>
    </method>

    <!-- ===== Button bindings ===== -->

    <!--
      Snapshot all buttons on a device's profile. `profile_index` is
      the hardware slot to read; pass `u32::MAX` (0xFFFFFFFF) to mean
      "currently active profile" — saves one round-trip.

      Returns: array of RatbagButton (D-Bus `(u(uua(uu))au)`):
        index          hardware button index (matches Profile.Buttons
                       ordering)
        action         (kind, value, macro_steps):
                         kind   ∈ button_action_kind (0=NONE, 1=MOUSE,
                                  2=SPECIAL, 3=KEY, 4=MACRO)
                         value  raw u32 for MOUSE/SPECIAL/KEY,
                                ignored for NONE/MACRO
                         macro_steps  list of (event_kind, value)
                                      where event_kind ∈ macro_event_kind
                                      (0=NONE, 1=PRESS, 2=RELEASE, 3=WAIT)
        supported_action_types  subset of button_action_kind the
                                firmware accepts on this button
    -->
    <method name="ListButtons">
      <arg name="device_path" type="o" direction="in"/>
      <arg name="profile_index" type="u" direction="in"/>
      <arg name="buttons" type="a(u(uua(uu))au)" direction="out"/>
    </method>

    <!--
      Write a binding. `profile_index = u32::MAX` targets the active
      profile. Implicitly Commits to hardware.
    -->
    <method name="SetButton">
      <arg name="device_path" type="o" direction="in"/>
      <arg name="profile_index" type="u" direction="in"/>
      <arg name="button_index" type="u" direction="in"/>
      <arg name="action" type="(uua(uu))" direction="in"/>
    </method>

    <!-- ===== LED state ===== -->

    <!--
      Snapshot all LEDs on a device's profile. `profile_index = u32::MAX`
      targets the currently-active profile.

      Returns: array of RatbagLed (D-Bus `(uu(uuu)uauu)`):
        index            hardware LED index (matches Profile.Leds ordering)
        mode             one of led_mode (0=OFF, 1=ON, 2=CYCLE, 3=BREATHING)
        color            (r, g, b), each 0..=255 (u32-encoded)
        brightness       0..=255 (clamped by ratbagd to per-device max)
        supported_modes  subset of led_mode the firmware accepts
        color_depth      one of led_color_depth (0=MONOCHROME, 1=RGB_888, 2=RGB_111)

      Returns an empty array for devices whose driver doesn't expose
      LED objects — same graceful no-affordance path the GUI uses for
      non-RGB mice.
    -->
    <method name="ListLeds">
      <arg name="device_path" type="o" direction="in"/>
      <arg name="profile_index" type="u" direction="in"/>
      <arg name="leds" type="a(uu(uuu)uauu)" direction="out"/>
    </method>

    <!--
      Write one LED's state (mode + color + brightness).
      `profile_index = u32::MAX` targets the active profile. Implicitly
      Commits to hardware. The wire shape of `led` is `(uu(uuu)u)`:
      (index, mode, (r, g, b), brightness).
    -->
    <method name="SetLed">
      <arg name="device_path" type="o" direction="in"/>
      <arg name="profile_index" type="u" direction="in"/>
      <arg name="led_index" type="u" direction="in"/>
      <arg name="led" type="(uu(uuu)u)" direction="in"/>
    </method>

    <!-- ===== Status snapshot ===== -->

    <!--
      Returns: (focused_app_id, last_switch_reason, rules_loaded).
      Encodes `gamerat_proto::types::StatusInfo`.
    -->
    <method name="Status">
      <arg name="status" type="(ssu)" direction="out"/>
    </method>

    <!-- ===== Signals ===== -->

    <!--
      Emitted *before* the daemon writes the new profile to the
      device — the GUI uses this to surface a "switching…"
      indicator covering the brief hardware-jitter window during
      the firmware commit.
    -->
    <signal name="ProfileSwitching">
      <arg name="device" type="o"/>
      <arg name="to_profile" type="u"/>
      <arg name="reason" type="s"/>
    </signal>

    <!-- Emitted after the daemon writes ActiveProfile + Commit to ratbagd. -->
    <signal name="ProfileSwitched">
      <arg name="device" type="o"/>
      <arg name="from_profile" type="u"/>
      <arg name="to_profile" type="u"/>
      <arg name="reason" type="s"/>
    </signal>

    <!--
      Emitted by the DPI tracker when the device's live active DPI
      stage changes. Requires the libratbag RefreshActive patch in
      gamerat's patches/libratbag/; without it the firmware-internal
      cycle is invisible and the tracker never fires.
    -->
    <signal name="ActiveDpiStageChanged">
      <arg name="device" type="o"/>
      <arg name="stage" type="u"/>
    </signal>

    <!-- Emitted on every focus event, whether or not a rule matched. -->
    <signal name="FocusChanged">
      <arg name="app_id" type="s"/>
      <arg name="title" type="s"/>
      <!--
        Source identifier; one of the constants exported by the
        `gamerat_proto::focus_source` module ("synthetic",
        "wlr-foreign-toplevel", "kwin", "x11", ...).
      -->
      <arg name="source" type="s"/>
    </signal>

    <!-- ===== Properties ===== -->

    <property name="Version" type="s" access="read"/>

    <!--
      When false, the dispatch loop emits FocusChanged but suppresses
      the rule-driven profile switch. Profile changes become purely
      manual (CLI / GUI). Persisted in
      `$XDG_CONFIG_HOME/gamerat/settings.toml`.
    -->
    <property name="AutoSwitchEnabled" type="b" access="readwrite"/>

    <!--
      When false, the dispatch loop skips the Desktop fallback on
      no-rule-match focus events — the current profile stays active.
      Useful for users who don't curate the Desktop slot but still
      want autoswitching between game profiles.
    -->
    <property name="DesktopReturnEnabled" type="b" access="readwrite"/>

    <!--
      Debounce window (milliseconds) before the Desktop fallback
      fires after a no-rule-match focus event. Briefly tabbing out
      of a game shorter than this delay rides out the non-game
      focus. 0 means "fire immediately" (legacy behaviour).
    -->
    <property name="DesktopReturnDelayMs" type="t" access="readwrite"/>

    <!--
      When true, the GUI raises a system notification each time a
      profile switch lands. Off by default — fullscreen gamers tend
      to find these noisy.
    -->
    <property name="NotifyOnProfileSwitch" type="b" access="readwrite"/>

  </interface>
</node>
