# Rust build artifacts
/target
**/*.rs.bk
Cargo.lock.bak

# IDE/editor
/.idea/
/.vscode/
*.swp
*.swo
.DS_Store
scripts/__pycache__/

# Local overrides
/.env
/.env.local
/.direnv/

# Coverage / profiling
*.profraw
/coverage/
/tarpaulin-report.html

# Frontend toolchain (per-crate gitignores own the rest)
node_modules/
.vite/
.pnpm-store/

# makepkg work dirs + outputs inside packaging/. The PKGBUILD
# unpacks into `src/`, fakeroots into `pkg/`, drops `*.pkg.tar.zst`
# next to itself — none of which should land in version control.
# (cargo-deb's target/debian/ and cargo-generate-rpm's
# target/generate-rpm/ are already covered by /target above.)
/packaging/arch/src/
/packaging/arch/pkg/
/packaging/arch/*.pkg.tar.*
/packaging/arch/*.log

# Binary tarball staging from scripts/build-tarball.sh
/gamerat-*-x86_64-linux.tar.gz

# Local Claude Code agent state (runtime lock, settings) — not project code.
/.claude/

# Language Check 
/crates/gamerat-gui/.languagecheck/
# Local-only design scratch — never track/push
/preliminary-design.md
