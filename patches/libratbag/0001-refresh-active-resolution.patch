diff --git a/src/driver-hidpp20.c b/src/driver-hidpp20.c
index 4a9b4c6..a071106 100644
--- a/src/driver-hidpp20.c
+++ b/src/driver-hidpp20.c
@@ -1733,6 +1733,41 @@ err:
 	return rc;
 }
 
+/*
+ * Re-query the device for its current active DPI index (HID++ 2.0
+ * feature 0x8100, command 0xb0 — GetCurrentDpiIndex). Walks the
+ * active profile's resolutions and sets `is_active` to mirror the
+ * firmware's current cycle position. Cheap: one HID++ short packet
+ * round-trip.
+ */
+static int
+hidpp20drv_refresh_active_resolution(struct ratbag_device *device)
+{
+	struct hidpp20drv_data *drv_data = ratbag_get_drv_data(device);
+	struct ratbag_profile *profile;
+	struct ratbag_resolution *resolution;
+	int dpi_index;
+
+	if (drv_data == NULL || drv_data->dev == NULL)
+		return -ENOTSUP;
+
+	dpi_index = hidpp20_onboard_profiles_get_current_dpi_index(drv_data->dev);
+	if (dpi_index < 0)
+		return dpi_index;
+
+	list_for_each(profile, &device->profiles, link) {
+		if (!profile->is_active)
+			continue;
+		list_for_each(resolution, &profile->resolutions, link) {
+			resolution->is_active =
+				(resolution->index == (unsigned int)dpi_index);
+		}
+		break;
+	}
+
+	return 0;
+}
+
 struct ratbag_driver hidpp20_driver = {
 	.name = "Logitech HID++2.0",
 	.id = "hidpp20",
@@ -1740,4 +1775,5 @@ struct ratbag_driver hidpp20_driver = {
 	.remove = hidpp20drv_remove,
 	.commit = hidpp20drv_commit,
 	.set_active_profile = hidpp20drv_set_current_profile,
+	.refresh_active_resolution = hidpp20drv_refresh_active_resolution,
 };
