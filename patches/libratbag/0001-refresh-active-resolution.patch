--- a/ratbagd/ratbagd-device.c
+++ b/ratbagd/ratbagd-device.c
@@ -221,6 +221,48 @@ static int ratbagd_device_commit(sd_bus_message *m,
 	return 0;
 }
 
+static int ratbagd_device_refresh_active(sd_bus_message *m,
+					 void *userdata,
+					 sd_bus_error *error)
+{
+	struct ratbagd_device *device = userdata;
+	int rc;
+	unsigned int i;
+
+	/* Refresh libratbag's cached active-resolution state from the
+	 * device. Driver-specific — HID++ 2.0 implements it, others
+	 * return -ENOTSUP and we propagate that to the caller.
+	 */
+	rc = ratbag_device_refresh_active_resolution(device->lib_device);
+	if (rc == -ENOTSUP)
+		return sd_bus_reply_method_errorf(m,
+						  SD_BUS_ERROR_NOT_SUPPORTED,
+						  "driver doesn't track active resolution");
+	if (rc < 0)
+		return sd_bus_reply_method_errorf(m,
+						  SD_BUS_ERROR_FAILED,
+						  "refresh failed: %d", rc);
+
+	/* Emit PropertiesChanged on every resolution of the active
+	 * profile so D-Bus clients with cached IsActive values pick up
+	 * the new state without a manual re-read.
+	 */
+	for (i = 0; i < device->n_profiles; i++) {
+		struct ratbagd_profile *profile = device->profiles[i];
+
+		if (!profile || !ratbagd_profile_get_is_active(profile))
+			continue;
+		ratbagd_for_each_resolution_signal(device->ctx->bus,
+						   profile,
+						   ratbagd_resolution_resync);
+		break;
+	}
+
+	CHECK_CALL(sd_bus_reply_method_return(m, "u", 0));
+
+	return 0;
+}
