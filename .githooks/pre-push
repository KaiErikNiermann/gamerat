#!/usr/bin/env bash
# gamerat pre-push hook.
#
# Runs the fast static checks that don't need a running ratbagd or
# desktop session. Tracked in the repo under .githooks/ so it ships with
# clones; enable per-checkout with:
#
#     git config core.hooksPath .githooks
#
# (Project-local, not global. Re-run after a fresh clone.)
#
# Set GAMERAT_SKIP_HOOKS=1 to bypass — useful for in-progress branches,
# but never push to main with it set.

set -euo pipefail

if [[ "${GAMERAT_SKIP_HOOKS:-0}" == "1" ]]; then
    echo "pre-push: GAMERAT_SKIP_HOOKS=1, skipping checks." >&2
    exit 0
fi

# Colors only when stderr is a tty.
if [[ -t 2 ]]; then
    bold=$'\033[1m'
    dim=$'\033[2m'
    red=$'\033[31m'
    green=$'\033[32m'
    reset=$'\033[0m'
else
    bold='' dim='' red='' green='' reset=''
fi

step() {
    echo "${bold}▸${reset} ${dim}$*${reset}" >&2
}

fail() {
    echo "${red}✘ pre-push failed:${reset} $*" >&2
    echo "${dim}  override with: GAMERAT_SKIP_HOOKS=1 git push${reset}" >&2
    exit 1
}

cd "$(git rev-parse --show-toplevel)"

# Tauri (gamerat-gui) needs webkit2gtk-4.1 on Linux to compile at all.
# If the dep isn't installed, skip the crate rather than blocking pushes.
cargo_excludes=()
if ! pkg-config --exists webkit2gtk-4.1 2>/dev/null; then
    cargo_excludes=(--exclude gamerat-gui)
    echo "${dim}  (skipping gamerat-gui rust checks: webkit2gtk-4.1 not installed)${reset}" >&2
fi

step "cargo fmt --all --check"
cargo fmt --all --check || fail "rustfmt would reformat tracked files"

step "cargo clippy --workspace ${cargo_excludes[*]:-} --all-targets -- -D warnings"
cargo clippy --workspace "${cargo_excludes[@]}" --all-targets --quiet -- -D warnings \
    || fail "clippy reported warnings"

step "cargo check --workspace ${cargo_excludes[*]:-} --all-targets"
cargo check --workspace "${cargo_excludes[@]}" --all-targets --quiet \
    || fail "workspace does not type-check"

if [[ -d crates/gamerat-gui/node_modules ]]; then
    step "pnpm --dir crates/gamerat-gui lint"
    pnpm --silent --dir crates/gamerat-gui lint || fail "eslint reported issues"

    step "pnpm --dir crates/gamerat-gui check"
    pnpm --silent --dir crates/gamerat-gui check || fail "svelte-check reported issues"
else
    echo "${dim}  (skipping frontend checks: crates/gamerat-gui/node_modules missing — run \`pnpm install\` there)${reset}" >&2
fi

# ratbagd-interface drift check. Snapshot mode only (live mode needs
# ratbagd + a connected mouse, neither guaranteed in CI). Catches
# accidental edits to the captured XML and proxy.rs falling out of
# sync with the snapshot.
step "python3 scripts/check_ratbagd_drift.py --mode snapshot --allow-extras"
python3 scripts/check_ratbagd_drift.py --mode snapshot --allow-extras \
    || fail "ratbagd interface drift detected (see scripts/check_ratbagd_drift.py)"

echo "${green}✔ pre-push checks passed${reset}" >&2
